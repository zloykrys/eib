apiVersion: 1.3
image:
  imageType: iso
  arch: x86_64
  baseImage: slemicro.iso
  outputImageName: eib-image.iso
operatingSystem:
  isoConfiguration:
    installDevice: /dev/vda
  packages:
    noGPGCheck: false
    sccRegistrationCode: "{{ scc_registration_code }}"
    packageList:
      - nfs-client
      - rpcbind
  kernelArgs:
    - selinux=0
  users:
    - username: root
      encryptedPassword: $6$jHugJNNd3HElGsUZ$eodjVe4te5ps44SVcWshdfWizrP.xAyd71CVEXazBJ/.v799/WRCBXxfYmunlBO2yp1hm/zb4r8EmnrrNCF.P/
    - username: user
      encryptedPassword: $6$jHugJNNd3HElGsUZ$eodjVe4te5ps44SVcWshdfWizrP.xAyd71CVEXazBJ/.v799/WRCBXxfYmunlBO2yp1hm/zb4r8EmnrrNCF.P/
kubernetes:
  version: v1.35.3+rke2r3
  network:
      apiHost: rancher-dev.demo.com
      apiVIP: 172.16.33.10
  nodes:
    - hostname: rke2-1.demo.com
      type: server
      initializer: true
    - hostname: rke2-2.demo.com
      type: server
    - hostname: rke2-3.demo.com
      type: server
  manifests:
    urls:
    - https://github.com/cert-manager/cert-manager/releases/download/v1.15.3/cert-manager.crds.yaml
  helm:
    charts:
      - name: rancher
        version: 2.14.1
        repositoryName: rancher-prime
        valuesFile: rancher-values.yaml
        targetNamespace: cattle-system
        createNamespace: true
        installationNamespace: kube-system
      - name: cert-manager
        installationNamespace: kube-system
        createNamespace: true
        repositoryName: jetstack
        targetNamespace: cert-manager
        version: 1.20.1
      - name: neuvector-crd
        version: 109.0.2+up2.10.2
        repositoryName: rancher-charts
        targetNamespace: cattle-neuvector-system
        createNamespace: true
        installationNamespace: kube-system
        valuesFile: neuvector-crd.yaml
      - name: neuvector
        version: 109.0.2+up2.10.2
        repositoryName: rancher-charts
        targetNamespace: cattle-neuvector-system
        createNamespace: true
        installationNamespace: kube-system
        valuesFile: neuvector-values.yaml
      - name: neuvector-monitor
        version: 109.0.2+up2.10.2
        repositoryName: rancher-charts
        targetNamespace: cattle-neuvector-system
        createNamespace: true
        installationNamespace: kube-system
      - name: cloudnative-pg
        repositoryName: appco
        version: 0.28.3
        targetNamespace: cloudnativepg
        createNamespace: true
        installationNamespace: kube-system
      - name: kubernetes-csi-driver-nfs
        repositoryName: appco
        version: 4.13.3
        targetNamespace: kubernetes-csi-driver-nfs
        createNamespace: true
        installationNamespace: kube-system
        valuesFile: kubernetes-csi-driver-nfs-values.yaml
# compliance operator
#
      - name: rancher-compliance-crd
        repositoryName: rancher-charts
        version: 109.1.0+up1.4.1
        targetNamespace: compliance-operator-system
        createNamespace: true
        installationNamespace: kube-system
      - name: rancher-compliance
        repositoryName: rancher-charts
